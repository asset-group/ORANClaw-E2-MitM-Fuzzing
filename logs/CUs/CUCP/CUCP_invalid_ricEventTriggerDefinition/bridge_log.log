class JsonFuzzer:
    def __init__(self, constraints, protocol_ie_map):
        self.constraints = constraints
        self.protocol_ie_map = protocol_ie_map
        self.asn1_files = asn1_files  # Using from global scope
        self.definitions = definitions  # Using from global scope
        self.target_keys = target_keys  # Using from global scope
        self.fuzz_history = {}  # Track previously fuzzed messages
        self.fuzz_success_rate = {}  # Track fuzzing success rate by message type
        
    def map_procedure_code(self, procedure_code):
        """Map ProcedureCode (as per O-RAN ASN.1 specification) to message types."""
        procedure_mapping = {
            0x01: "E2setup",
            0x02: "ErrorIndication",
            0x03: "Reset",
            0x04: "RICcontrol",
            0x05: "RICindication",
            0x06: "RICserviceQuery",
            0x07: "RICserviceUpdate",
            0x08: "RICsubscription",
            0x09: "RICsubscriptionDelete",
            0x0A: "E2nodeConfigurationUpdate",
            0x0B: "E2connectionUpdate",
            0x0C: "RICsubscriptionDeleteRequired",
            0x0D: "E2removal",
            0x0E: "E42setup",
            0x0F: "E42RICsubscription",
            0x10: "E42RICsubscriptionDelete",
            0x11: "E42RICcontrol",
            0x12: "E42updateE2node",
            # Add other procedure codes if necessary
        }
        return procedure_mapping.get(procedure_code, "UnknownProcedureCode")

    def guess_message_type(self, msg):
        """Try to identify the message type from SCTP payload using ProcedureCode and ASN.1 structure."""
        try:
            if len(msg) < 4:
                return None
            
            msg_type = msg[0]
            procedure_code = msg[1]
            
            print(f"[*] ProcedureCode: {hex(procedure_code)}")            
            message_type = self.map_procedure_code(procedure_code)
            
            return message_type

        except Exception as e:
            print(Fore.RED + f"Error guessing message type: {e}")
            return "Error guessing message type"
    
    def hex_to_json(self, hex_data):
        """Convert hex data to JSON using the reader tool, ignore empty/incomplete messages."""
        if not hex_data or not str(hex_data).strip():
            return None

        try:
            reader_command = ['./reader', '-hex', str(hex_data)]
            reader_output = subprocess.check_output(reader_command).decode('utf-8').strip()

            if not reader_output:
                return None

            try:
                json_data = json.loads(reader_output)
                return json_data if json_data else None

            except json.JSONDecodeError as e:
                print(Fore.YELLOW + f"[!] Ignored invalid JSON: {e}")
                return None

        except subprocess.CalledProcessError as e:
            print(Fore.RED + f"[!] Reader command failed: {e}")
            return None

        except Exception as e:
            print(Fore.RED + f"[!] Unexpected error: {e}")
            return None

    def json_to_hex(self, json_data):
        """Convert JSON data back to hex using the reader_json tool."""
        try:
            with tempfile.NamedTemporaryFile(mode='w', suffix='.json', delete=False) as temp_file:
                json.dump(json_data, temp_file)
                temp_file_path = temp_file.name
            try:
                reader_json_command = ['./reader_json', '-json', temp_file_path]
                hex_output = subprocess.check_output(reader_json_command).decode('utf-8').strip()
                return hex_output
            finally:
                os.unlink(temp_file_path)
        
        except subprocess.CalledProcessError as e:
            print(Fore.RED + f"reader_json command failed: {e}")
            return None
        except Exception as e:
            print(Fore.RED + f"Error converting JSON to hex: {e}")
            return None
        
        
    def get_random_value(self, constraints, field_name):
        """Find all matching fields in constraints and return a randomly selected value."""
        matching_values = []
        stack = [constraints]
        
        while stack:
            current = stack.pop()

            if isinstance(current, dict):
                for key, value in current.items():
                    if key == field_name:
                        if isinstance(value, dict):
                            # Handle specific types based on constraints
                            if "min" in value and "max" in value:
                                if value["min"] is not None and value["max"] is not None:
                                    matching_values.append(("integer", value["min"], value["max"]))
                            if "alphabet" in value:
                                alphabet = value.get("alphabet", string.ascii_letters + string.digits + " ")
                                min_len = value.get("min", 1)
                                max_len = value.get("max", len(alphabet))
                                matching_values.append(("string", alphabet, min_len, max_len))
                            if value.get("type_name") == "BITSTRING":
                                length = value.get("min", 8)
                                matching_values.append(("bitstring", length))
                            if value.get("type_name") == "OCTETSTRING":
                                length = value.get("min", 1)
                                matching_values.append(("octetstring", length))
                            if value.get("type_name") == "ENUMERATED":
                                enum_values = value.get("enumerations", [])
                                if enum_values:
                                    matching_values.append(("enum", enum_values))
                            if "root_members" in value:
                                stack.append(value["root_members"])

                        # Handle CHOICE type
                        if value.get("type_name") == "CHOICE":
                            choice_values = value.get("choices", [])
                            if choice_values:
                                matching_values.append(("choice", choice_values))

                    elif isinstance(value, dict):
                        stack.append(value)
                    elif isinstance(value, list):
                        stack.extend(value)

            elif isinstance(current, list):
                stack.extend(current)

        # If we found matching values, randomly select one and generate a value
        if matching_values:
            # Use random.choice to select from all possible matches
            value_type = random.choice(matching_values)
            print(Fore.LIGHTCYAN_EX + f"[DEBUG] Random value type selected: {value_type}")
            if value_type[0] == "integer":
                return random.randint(value_type[1], value_type[2])
            elif value_type[0] == "string":
                alphabet, min_len, max_len = value_type[1], value_type[2], value_type[3]
                length = random.randint(min_len, max_len)
                return ''.join(random.choice(alphabet) for _ in range(length))
            elif value_type[0] == "bitstring":
                length = value_type[1]
                return ''.join(random.choice('01') for _ in range(length))
            elif value_type[0] == "octetstring":
                length = value_type[1]
                return bytes([random.randint(0, 255) for _ in range(length)])
            elif value_type[0] == "enum":
                enum_values = value_type[1]
                return random.choice(enum_values)
            elif value_type[0] == "choice":
                choice_values = value_type[1]
                return random.choice(choice_values)
        
        return None

    def field_exists(self, data, field_name):
        """Check if a field exists in nested data structure."""
        if not isinstance(data, (dict, list, tuple)) or isinstance(data, str):
            return False
            
        if isinstance(data, dict):
            # Direct match in keys
            if field_name in data:
                return True
            # Check all values
            for value in data.values():
                if self.field_exists(value, field_name):
                    return True
        # For lists and tuples
        elif isinstance(data, (list, tuple)):
            # Special case: field_name is the first element in a tuple
            if len(data) > 0 and data[0] == field_name:
                return True
            # Check all elements
            for item in data:
                if self.field_exists(item, field_name):
                    return True
        return False

    def get_all_fields(self, data, prefix="", result=None):
        """
        Extract all field names from nested data structure.
        Returns a list of field paths.
        """
        if result is None:
            result = []
            
        if isinstance(data, dict):
            for key, value in data.items():
                current_path = f"{prefix}.{key}" if prefix else key
                result.append(current_path)
                if isinstance(value, (dict, list, tuple)) and not isinstance(value, str):
                    self.get_all_fields(value, current_path, result)
        elif isinstance(data, list):
            for i, item in enumerate(data):
                current_path = f"{prefix}[{i}]"
                if isinstance(item, tuple) and len(item) >= 2:
                    result.append(item[0])
                if isinstance(item, (dict, list, tuple)) and not isinstance(item, str):
                    self.get_all_fields(item, current_path, result)
                    
        return result


    def collect_all_constraint_fields(self, constraints):
        """Collect all field names from constraints to ensure even distribution."""
        all_fields = set()
        stack = [constraints]
        
        while stack:
            current = stack.pop()
            
            if isinstance(current, dict):
                for key, value in current.items():
                    # Add all keys as potential field names
                    all_fields.add(key)
                    
                    if isinstance(value, dict):
                        stack.append(value)
                    elif isinstance(value, list):
                        stack.extend(value)
            elif isinstance(current, list):
                stack.extend(current)
                
        return all_fields

    def mutate_field(self, json_data, constraints, field_name):
        """Find and mutate a specific field in the JSON data."""
        mutated = False
        
        # First check if field exists
        if not self.field_exists(json_data, field_name):
            print(Fore.YELLOW + f"[!] Field '{field_name}' not found. Skipping mutation.")
            return json_data, mutated
        else:
            # Get a random value for this field based on constraints
            random_value = self.get_random_value(constraints, field_name)
            if random_value is None:
                print(Fore.YELLOW + f"[!] No constraints found for '{field_name}'. Skipping mutation.")
                return json_data, mutated
                
            print(Fore.LIGHTCYAN_EX + f"[DEBUG] Random value chosen for {field_name}: {random_value}")

            # Traverse the data structure to find and mutate the field
            stack = [json_data]
            while stack:
                current = stack.pop()
                if isinstance(current, dict):
                    for key, value in current.items():
                        if key == field_name and isinstance(value, (int, float, str)):
                            print(Fore.RED + f"[+] Mutating {field_name}: {value} -> {random_value}")
                            current[key] = random_value
                            mutated = True
                        elif isinstance(value, (dict, list, tuple)):
                            stack.append(value)
                elif isinstance(current, (list, tuple)):
                    for i in range(len(current)):
                        item = current[i]
                        if isinstance(item, tuple) and len(item) >= 2 and item[0] == field_name:
                            print(Fore.RED + f"[+] Mutating {field_name} tuple: {item[1]} -> {random_value}")
                            if isinstance(current, list):  # Can only modify lists, not tuples
                                current[i] = (field_name, random_value)
                                mutated = True
                        elif isinstance(item, (dict, list, tuple)):
                            stack.append(item)

        return json_data, mutated

    def mutate_json(self, json_data, message_type=None, mutation_probability=0.7, max_mutations=1):
        """
        Intelligently mutate the JSON data based on message type and field constraints.
        
        Args:
            json_data (dict): The JSON data to mutate
            message_type (str): Type of message (for targeted fuzzing)
            mutation_probability (float): Probability of mutation (0.0 to 1.0)
            max_mutations (int): Maximum number of fields to mutate
            
        Returns:
            tuple: (mutated_json, list_of_mutations)
        """
        # Skip mutation based on probability
        if random.random() > mutation_probability:
            print(Fore.BLUE + "[*] Skipping mutation based on probability.")
            return json_data, []
        
        # Deep copy to avoid modifying the original
        import copy
        mutated_json = copy.deepcopy(json_data)
        
        # Try to find all field names in the JSON structure
        all_json_fields = self.get_all_fields(json_data)
        
        json_field_names = set()
        for field in all_json_fields:
            # Extract just the field name from the path
            field_name = field.split('.')[-1]
            if field_name.startswith('['):
                continue  # Skip array indices
            json_field_names.add(field_name)
        
        # Get all field names from constraints to avoid bias
        constraint_field_names = self.collect_all_constraint_fields(self.constraints)
        
        #valid_fields = self.collect_all_constraint_fields(self.constraints)
        
        # Find fields that exist in both the JSON and have constraints
        valid_fields = []
        for field_name in json_field_names:
            if self.get_random_value(self.constraints, field_name) is not None:
                valid_fields.append(field_name)
        
        # Add some randomness - occasionally test randomly selected constraint fields 
        # even if they don't appear in current JSON (to test field addition)
        if random.random() < 0.5:  # 20% chance
            
            potential_new_fields = constraint_field_names - json_field_names
            
            #potential_new_fields  = valid_fields - json_field_names

            if potential_new_fields:
                sample_size = min(2, len(potential_new_fields))
                random_fields = random.sample(list(potential_new_fields), sample_size)
                valid_fields.extend(random_fields)
        
        if not valid_fields:
            print(Fore.YELLOW + "[!] No mutable fields with valid constraints found.")
            return mutated_json, []
            
        # Determine how many fields to mutate
        num_fields = min(max_mutations, len(valid_fields))
        
        # Priority fields for specific message types
        priority_fields = {
            "RICindication": ["ricInstanceID", "ricActionID", "ricIndicationSN", "ricIndicationType"],
            "RICcontrol": ["ricRequestorID", "ricControlStatus", "ricControlAckRequest"],
            "RICsubscription": ["ricRequestID", "ricActionID", "ricEventTriggerDefinition"],
            "E2setup": ["ranFunctionID","globalE2NodeID"],
        }
        
        # Fields to mutate - balanced approach
        fields_to_mutate = []
        
        # If we know the message type and have priority fields for it
        if message_type and message_type in priority_fields:
            # First try to include at least one priority field if available
            priority_candidates = [f for f in priority_fields[message_type] if f in valid_fields]
            if priority_candidates:
                # Select at least one but at most half of the mutations from priority fields
                priority_count = min(len(priority_candidates), max(1, num_fields // 2))
                priority_selected = random.sample(priority_candidates, priority_count)
                fields_to_mutate.extend(priority_selected)
            
            # Fill remaining spots with random fields
            remaining = num_fields - len(fields_to_mutate)
            if remaining > 0:
                random_candidates = [f for f in valid_fields if f not in fields_to_mutate]
                if random_candidates:
                    random_selected = random.sample(random_candidates, min(remaining, len(random_candidates)))
                    fields_to_mutate.extend(random_selected)
        else:
            # Just choose random fields with equal probability
            fields_to_mutate = random.sample(valid_fields, min(num_fields, len(valid_fields)))
        
        # Visualize the field selection for debugging
        print(Fore.CYAN + f"[DEBUG] Selected fields to mutate: {fields_to_mutate}")
        
        # Track mutations
        mutations = []
        
        # Mutate each selected field
        for field in fields_to_mutate:
            mutated_json, did_mutate = self.mutate_field(mutated_json, self.constraints, field)
            if did_mutate:
                # Get the IE name if it's a Protocol IE
                ie_name = None
                if field == "id" and self.field_exists(mutated_json, "id"):
                    # Try to find the actual ID value to map to a name
                    stack = [mutated_json]
                    while stack:
                        current = stack.pop()
                        if isinstance(current, dict) and "id" in current:
                            id_value = current["id"]
                            ie_name = self.protocol_ie_map.get(id_value, f"Unknown ID: {id_value}")
                            break
                        elif isinstance(current, (dict, list)):
                            if isinstance(current, dict):
                                stack.extend(current.values())
                            else:
                                stack.extend(current)
                
                mutations.append({
                    "field": field,
                    "ie_name": ie_name
                })
        
        if mutations:
            print(Fore.GREEN + f"[*] Successfully mutated {len(mutations)} fields: {', '.join([m['field'] for m in mutations])}")
        
        # Update history for this message type
        if message_type:
            if message_type not in self.fuzz_history:
                self.fuzz_history[message_type] = []
            
            self.fuzz_history[message_type].append({
                "time": time.time(),
                "mutations": mutations,
                "success": bool(mutations)
            })
            
            # Update success rate
            all_attempts = len(self.fuzz_history[message_type])
            successful = sum(1 for entry in self.fuzz_history[message_type] if entry["success"])
            self.fuzz_success_rate[message_type] = successful / all_attempts if all_attempts > 0 else 0
            
        return mutated_json, mutations


    def extract_asn1_content(self, json_data):
        """Try to extract ASN.1 content from specific fields in the JSON."""
        results = []
        
        def search_hex_fields(data, path=""):
            if isinstance(data, dict):
                for key, value in data.items():
                    if key in self.target_keys and isinstance(value, str) and re.fullmatch(r'[0-9A-Fa-f]+', value):
                        # Found a potential ASN.1 encoded hex string
                        results.append({
                            "path": f"{path}.{key}" if path else key,
                            "hex": value
                        })
                    elif isinstance(value, (dict, list)):
                        search_hex_fields(value, f"{path}.{key}" if path else key)
            elif isinstance(data, list):
                for i, item in enumerate(data):
                    search_hex_fields(item, f"{path}[{i}]")
                    
        search_hex_fields(json_data)
        return results
    
    def decode_asn1_content(self, hex_string, definition=None):
        """Try to decode ASN.1 content using different ASN.1 specifications."""
        for asn1_name, asn1_compiled in self.asn1_files.items():
            # If definition is specified, only try that one
            defs_to_try = [definition] if definition else self.definitions
            
            for definition in defs_to_try:
                try:
                    decoded = asn1_compiled.decode(definition, unhexlify(hex_string))
                    return {
                        "asn1_spec": asn1_name,
                        "definition": definition,
                        "decoded": decoded
                    }
                except Exception:
                    continue
        return None

    def smart_fuzz_asn1(self, json_data, message_type=None):
        """Intelligently fuzz ASN.1 encoded content within the JSON."""
        # Extract potential ASN.1 encoded fields
        asn1_fields = self.extract_asn1_content(json_data)
        print(Fore.CYAN + f"[*] Found {len(asn1_fields)} potential ASN.1 encoded fields.")
        print(Fore.CYAN + f"[*] ASN.1 fields: {', '.join([f['path'] for f in asn1_fields])}")
        if not asn1_fields:
            print(Fore.YELLOW + "[!] No potential ASN.1 encoded fields found.")
            return json_data
            
        # Deep copy JSON to avoid modifying original
        import copy
        modified_json = copy.deepcopy(json_data)
        
        # Try to decode and fuzz each field
        for field in asn1_fields:
            # Skip short hex values (likely not valid ASN.1)
            if len(field["hex"]) <= 18:
                continue
                
            # Try to decode
            decoded = self.decode_asn1_content(field["hex"])
            if not decoded:
                continue
                
            print(Fore.GREEN + f"[+] Successfully decoded {field['path']} as {decoded['definition']}")
            
            # Get potential fields to mutate from the decoded ASN.1
            asn1_content = decoded["decoded"]
            
            # For specific ASN.1 definitions, target specific fields but don't always use the same ones
            potential_target_fields = {
                "E2SM-KPM-ActionDefinition": [
                    "granulPeriod", "subscriptionID", "reportingPeriod", "cellObjID", 
                    "measInfoList", "cellGlobalID", "measType"
                ],
                "E2SM-KPM-IndicationMessage": [
                    "timestamp", "reportPeriod", "cellMeasObjectID", "measInfoList",
                    "granulPeriod", "measData", "measInfoID", "measValue" 
                ],
                "E2SM-RC-ControlMessage": [
                    "ranParameterValue", "ranParameterID", "ranParameter-Name",
                    "ranParameter-Test", "ranParameter-Definition", "ueID"
                ]
            }
            
            # # Select target fields with randomization
            # target_fields = []
            
            # if decoded["definition"] in potential_target_fields:
            #     # Get field names for this specific definition
            #     definition_fields = potential_target_fields[decoded["definition"]]
                
            #     # Select a random subset (1-3) of the fields to target
            #     num_to_select = random.randint(1, min(3, len(definition_fields)))
            #     target_fields = random.sample(definition_fields, num_to_select)
            
            # If no specific targets or no targets selected, try any random fields
            if not target_fields:
                field_paths = self.get_all_fields(asn1_content)
                field_names = [path.split('.')[-1] for path in field_paths]
                print(Fore.CYAN + f"[DEBUG] field names: {field_names}")
                field_names = list(set([f for f in field_names if not f.startswith('[')]))
                if field_names:
                    target_fields = random.sample(field_names, min(2, len(field_names)))
            
            # Log which fields we're targeting for this message
            print(Fore.CYAN + f"[DEBUG] ASN.1 targeting fields: {target_fields}")
            
            # Try to mutate each target field
            for target_field in target_fields:
                asn1_content, mutated = self.mutate_field(asn1_content, self.constraints, target_field)
                if mutated:
                    print(Fore.GREEN + f"[+] Mutated field '{target_field}' in {decoded['definition']}")
                    
            # Re-encode the mutated content
            try:
                encoded = decoded["asn1_spec"].encode(str(decoded["definition"]), str(asn1_content))
                encoded_hex = hexlify(encoded).decode()
                
                print(Fore.GREEN + f"[+] Successfully re-encoded and updated {field['path']}")
                
            except Exception as e:
                print(Fore.RED + f"[!] Error re-encoding ASN.1: {e}")
        
        return modified_json

    def process_message(self, msg, direction="to_ric"):
        """Process SCTP message, applying fuzzing based on direction."""
        try:
            # Convert message to hex for processing
            msg_hex = hexlify(msg).decode()
            
            # Only fuzz messages going to RIC
            if direction == "to_ric":
                # Identify message type
                message_type = self.guess_message_type(msg)
                print(Fore.CYAN + f"[*] Processing {message_type} message ({len(msg)} bytes)")
                print(Fore.GREEN + f"Before decoding:\n{msg_hex}")
                # Convert to JSON
                json_data = self.hex_to_json(msg_hex)
                if not json_data:
                    print(Fore.YELLOW + "[!] Failed to convert message to JSON. Skipping fuzzing.")
                    return msg
                #print(Fore.GREEN + "Converted to JSON:")
                #print(json.dumps(json_data, indent=2))  
                
                # Apply intelligent fuzzing based on message type
                # 1. Try to fuzz any ASN.1 content first (deep fuzzing)
                fuzzed_json = self.smart_fuzz_asn1(json_data, message_type)
                
                # 2. Then fuzz the message structure itself (surface fuzzing)
                fuzzed_json, mutations = self.mutate_json(fuzzed_json, message_type)
                
                #print("Mutated JSON:", json.dumps(fuzzed_json, indent=2))
                
                
                # If we made any changes, convert back to hex
                if mutations:
                    modified_hex = self.json_to_hex(fuzzed_json)
                    if modified_hex and modified_hex.strip():
                        modified_msg = unhexlify(modified_hex)
                        print(Fore.GREEN + f"[+] Successfully fuzzed message ({len(modified_msg)} bytes)")
                        print(Fore.GREEN + f"[+] Encoded again:\n{modified_hex}")
                        return modified_msg
                    else:
                        print(Fore.RED + "[-] Failed to convert fuzzed JSON back to hex. Using original message.")
                        print(Fore.RED + f"[-] Attempted to modify ehx:\n{modified_msg}")
                        print(Fore.RED + f"[-] Fuzzed JSON:\n{json.dumps(fuzzed_json, indent=2)}")
                else:
                    print(Fore.BLUE + "[*] No mutations applied to this message.")
            
            # Return original message if not modified or if going to xApp
            return msg
            
        except Exception as e:
            print(Fore.RED + f"[-] Error processing message: {e}")
            import traceback
            traceback.print_exc()
            return msg  # Return original on error


    
class SCTPMITMProxy:
    
    def __init__(self, mitm_ip=IP_MITM, xapp_ip=IP_XAPP, ric_ip=IP_RIC, port=PORT):
        self.mitm = mitm_ip
        self.xapp = xapp_ip
        self.ric_ip = ric_ip
        self.port = port
        self.server = None
        self.conn_from_xapp = None
        self.ric_client = None
        self.captures_folder = "/media/p3rplex/data3/Backup_ubuntu22/oran-orchestration/captures_bridge"
            
            
        # Initialize the enhanced fuzzer
        self.fuzzer = JsonFuzzer(constraints, protocolIEs)
        
        # Fuzzing statistics
        self.messages_processed = 0
        self.messages_fuzzed = 0
        self.fuzzing_start_time = time.time()
        
        # Fuzzing configuration
        self.fuzz_enabled = True
        self.fuzz_probability = 0.7  # 70% chance to fuzz each message
        self.max_mutations = 1  # Maximum mutations per message
        
        
        # Ensure the captures_bridge folder exists
        if not os.path.exists(self.captures_folder):
            os.makedirs(self.captures_folder)
            print(Fore.GREEN + f"[+] Created folder: {self.captures_folder}")
            
    def start(self):
            try:
                # RIC connection is stable
                self.ric_client = sctp.sctpsocket_tcp(socket.AF_INET)
                self.ric_client.bind((self.mitm, 0))  
                self.ric_client.connect((self.ric_ip, self.port))
                print(Fore.GREEN + f"[+] Connected to RIC at {self.ric_ip}:{self.port}")

                # Set up SCTP server to accept xApp connections
                self.server = sctp.sctpsocket_tcp(socket.AF_INET)
                self.server.bind((self.mitm, self.port))
                self.server.listen(1)
                print(Fore.YELLOW + f"[*] Listening for xApp on {self.mitm}:{self.port}...")
                print(Fore.CYAN + f"[*] Fuzzing enabled: {self.fuzz_enabled} (Probability: {self.fuzz_probability*100}%)")

                # Loop to accept new xApp connections
                while True:
                    print(Fore.YELLOW + "[*] Waiting for new xApp connection...")
                    self.conn_from_xapp, addr = self.server.accept()
                    print(Fore.GREEN + f"[+] Accepted xApp connection from {addr}")

                    # Handle the traffic in its own function
                    try:
                        self.proxy_traffic()
                    except Exception as e:
                        print(Fore.RED + f"[-] Proxy error: {e}")
                        import traceback
                        traceback.print_exc()

                    # Clean up and wait for new xApp connection
                    self.cleanup_xapp()

            except KeyboardInterrupt:
                print(Fore.RED + "\n[!] KeyboardInterrupt: Shutting down proxy.")
                self.print_statistics()
            except Exception as e:
                print(Fore.RED + f"[-] Unhandled error in start(): {e}")
                import traceback
                traceback.print_exc()
            finally:
                self.close_all()
                
    def cleanup_xapp(self):
        try:
            if self.conn_from_xapp:
                print(Fore.YELLOW + "[*] Cleaning up xApp connection.")
                self.conn_from_xapp.close()
                self.conn_from_xapp = None
        except Exception as e:
            print(Fore.RED + f"[-] Error during xApp cleanup: {e}")

    def close_all(self):
        try:
            if self.conn_from_xapp:
                self.conn_from_xapp.close()
            if self.ric_client:
                self.ric_client.close()
            if self.server:
                self.server.close()
            print(Fore.CYAN + "[*] Closed all sockets. Goodbye!")
        except Exception as e:
            print(Fore.RED + f"[-] Error closing sockets: {e}")

            
